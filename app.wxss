/**
 * Design tokens: docs/stitch_prd_design_generator/DESIGN.md (Lovable-inspired).
 * Manrope: 需在小程序「downloadFile 合法域名」加入 fonts.gstatic.com 后网络字体方可生效；失败时回退系统字体。
 */
@font-face {
  font-family: Manrope;
  font-style: normal;
  font-weight: 400;
  font-display: swap;
  src: url('https://fonts.gstatic.com/s/manrope/v15/xn7_YHE41ni1AdIRqAuZuw1Nz9IKIQ.woff2') format('woff2');
}

@font-face {
  font-family: Manrope;
  font-style: normal;
  font-weight: 600;
  font-display: swap;
  src: url('https://fonts.gstatic.com/s/manrope/v15/xn7gYHE41ni1AdIRggmxSvfedN4.woff2') format('woff2');
}

page {
  /* Canvas */
  --page-bg: #f7f4ed;
  --background-parchment: #f7f4ed;
  /* Surfaces (DESIGN.md YAML) */
  --surface: #fdf8f8;
  --surface-container-lowest: #ffffff;
  --surface-container-low: #f7f3f2;
  --surface-container: #f1edec;
  --surface-container-high: #ebe7e6;
  --surface-container-highest: #e5e2e1;
  /* Text */
  --foreground: #1c1b1b;
  --on-surface-variant: #444748;
  --muted-foreground: #5f5f5d;
  /* Borders */
  --border-subtle: #eceae4;
  --border-interactive: rgba(28, 28, 28, 0.4);
  --border: var(--border-subtle);
  --border-strong: var(--border-interactive);
  /* Cards / elevated */
  --card: #ffffff;
  --card-foreground: #1c1b1b;
  --surface-muted: var(--surface-container-low);
  --log-card-bg: var(--background-parchment);
  /* Primary / CTA */
  --charcoal-primary: #1c1c1c;
  --off-white-highlight: #fcfbf8;
  --primary: #1c1c1c;
  --primary-foreground: #fcfbf8;
  --accent: #1c1c1c;
  --accent-strong: #1c1c1c;
  --accent-soft: rgba(28, 28, 28, 0.08);
  --accent-muted: rgba(28, 28, 28, 0.05);
  --background: var(--page-bg);
  --destructive: #ba1a1a;
  --ring: rgba(59, 130, 246, 0.45);
  --inset-highlight: inset 0 0.5px 0 rgba(255, 255, 255, 0.2),
    inset 0 0 0 0.5px rgba(0, 0, 0, 0.2), 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
  /* Form surfaces (light) */
  --input-bg: #ffffff;
  --input-border: var(--border-subtle);
  --input-color: var(--foreground);

  background-color: var(--page-bg);
  color: var(--foreground);
  font-family:
    Manrope,
    'PingFang SC',
    'HarmonyOS Sans SC',
    'MIUI',
    -apple-system,
    BlinkMacSystemFont,
    'Segoe UI',
    sans-serif;
  min-height: 100%;
}

.page-root {
  min-height: 100vh;
  box-sizing: border-box;
  background-color: var(--page-bg);
  color: var(--foreground);
}

.page-root.theme-dark,
.theme-dark {
  --page-bg: #2a2929;
  --background-parchment: #2a2929;
  --surface: #3a3838;
  --surface-container-lowest: #3a3838;
  --surface-container-low: rgba(255, 255, 255, 0.05);
  --surface-container: rgba(255, 255, 255, 0.08);
  --surface-container-high: rgba(255, 255, 255, 0.1);
  --surface-container-highest: rgba(255, 255, 255, 0.14);
  --foreground: #f4f0ef;
  --on-surface-variant: rgba(244, 240, 239, 0.72);
  --muted-foreground: rgba(244, 240, 239, 0.68);
  --border-subtle: rgba(244, 240, 239, 0.14);
  --border-interactive: rgba(244, 240, 239, 0.45);
  --border: var(--border-subtle);
  --border-strong: var(--border-interactive);
  --card: #3a3838;
  --card-foreground: #f4f0ef;
  --surface-muted: rgba(255, 255, 255, 0.06);
  --log-card-bg: #323130;
  --charcoal-primary: #f4f0ef;
  --primary: #fcfbf8;
  --primary-foreground: #1c1c1c;
  --accent: #f4f0ef;
  --accent-strong: #ffffff;
  --accent-soft: rgba(255, 255, 255, 0.1);
  --accent-muted: rgba(255, 255, 255, 0.07);
  --background: var(--page-bg);
  --destructive: #ff8a80;
  --ring: rgba(96, 165, 250, 0.5);
  --inset-highlight: inset 0 0.5px 0 rgba(255, 255, 255, 0.35),
    inset 0 0 0 0.5px rgba(0, 0, 0, 0.35), 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
  --input-bg: #323030;
  --input-border: rgba(244, 240, 239, 0.22);
  --input-color: var(--foreground);
}

/* Typography scale (DESIGN.md → rpx, mobile-first) */
.ds-display {
  font-size: 72rpx;
  font-weight: 600;
  line-height: 1.05;
  letter-spacing: -1.5px;
  color: var(--foreground);
}

.ds-hero-title {
  font-size: 72rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.9px;
  color: var(--foreground);
}

.ds-screen-title {
  font-size: 72rpx;
  font-weight: 600;
  line-height: 1;
  letter-spacing: -1.2px;
  color: var(--foreground);
}

.ds-page-title {
  font-size: 80rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -0.9px;
  color: var(--foreground);
}

.ds-section-heading {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.25;
  color: var(--foreground);
}

.ds-card-title {
  font-size: 36rpx;
  font-weight: 500;
  line-height: 1.25;
  color: var(--foreground);
}

.ds-body {
  font-size: 32rpx;
  font-weight: 400;
  line-height: 1.5;
  color: var(--foreground);
}

.ds-body-lg {
  font-size: 36rpx;
  font-weight: 400;
  line-height: 1.38;
  color: var(--foreground);
}

.ds-caption {
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.5;
  color: var(--muted-foreground);
}

.ds-label-caps {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--muted-foreground);
}

.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 28rpx 56rpx;
}

.card {
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
  background: var(--card);
  color: var(--card-foreground);
  box-shadow: 0 2rpx 12rpx rgba(28, 28, 28, 0.04);
}

.theme-dark .card {
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.35);
}

.accent-fill-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 16rpx;
  border: none;
  background-color: var(--accent);
  color: var(--primary-foreground);
  box-shadow: var(--inset-highlight);
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 0.02em;
}

.accent-fill-button[disabled],
.accent-fill-button.button-loading {
  opacity: 0.72;
}

.accent-fill-button::after {
  border: none;
}

.muted-text {
  color: var(--muted-foreground);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 20rpx;
  background: var(--primary);
  color: var(--primary-foreground);
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: var(--inset-highlight);
}

.primary-button[disabled] {
  opacity: 0.64;
}

.tile-active {
  opacity: 0.88;
}

.ph-muted {
  color: var(--muted-foreground);
  opacity: 0.85;
}

.field-input {
  background: var(--input-bg);
  border: 2rpx solid var(--input-border);
  color: var(--input-color);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.page-shell.has-tab {
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}
