page {
  --background: #eef6f5;
  --background-top: #e0f2f1;
  --foreground: #0f172a;
  --card: #ffffff;
  --card-foreground: #0f172a;
  --primary: #18181b;
  --primary-foreground: #ffffff;
  --muted: #f1f5f9;
  --muted-foreground: #64748b;
  --border: rgba(15, 118, 110, 0.12);
  --destructive: #dc2626;
  --ring: rgba(13, 148, 136, 0.35);
  --accent: #0d9488;
  --accent-strong: #0f766e;
  --accent-soft: rgba(13, 148, 136, 0.14);
  --accent-muted: rgba(13, 148, 136, 0.08);

  min-height: 100%;
  background: linear-gradient(180deg, var(--background-top) 0%, var(--background) 42%, var(--background) 100%);
  background-color: var(--background);
  color: var(--foreground);
  font-family:
    "PingFang SC",
    "HarmonyOS Sans SC",
    "MIUI",
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;
}

.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 40rpx 28rpx 56rpx;
}

.card {
  border: 1rpx solid var(--border);
  border-radius: 36rpx;
  background: var(--card);
  color: var(--card-foreground);
  box-shadow:
    0 8rpx 32rpx rgba(15, 118, 110, 0.06),
    0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.accent-fill-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 999rpx;
  border: none;
  background: linear-gradient(135deg, var(--accent) 0%, #14b8a6 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.accent-fill-button[disabled],
.accent-fill-button.button-loading {
  opacity: 0.72;
}

.accent-fill-button::after {
  border: none;
}

.muted-text {
  color: var(--muted-foreground);
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  border-radius: 20rpx;
  background: var(--primary);
  color: var(--primary-foreground);
  font-size: 32rpx;
  font-weight: 600;
}

.primary-button[disabled] {
  opacity: 0.64;
}

.tile-active {
  opacity: 0.88;
}
