.profile-scroll {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx 28rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-hero-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx 48rpx;
  border-radius: 48rpx;
  border: 1rpx solid var(--border-subtle, var(--border));
  background: var(--surface-container-low, var(--card));
  margin-bottom: 16rpx;
}

.profile-avatar-wrap {
  position: relative;
  margin-bottom: 32rpx;
}

.profile-avatar-ring {
  width: 256rpx;
  height: 256rpx;
  border-radius: 999rpx;
  padding: 8rpx;
  border: 6rpx solid var(--accent);
  background: var(--surface-container-lowest, #fff);
  box-sizing: border-box;
}

.profile-avatar-inner {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  background: var(--secondary-container, #e5e2db);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  font-weight: 700;
  color: var(--muted-foreground);
}

.profile-edit-fab {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--primary-foreground);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  border: 4rpx solid var(--surface-container-low, var(--card));
}

.profile-name-block {
  text-align: center;
  margin-bottom: 28rpx;
}

.profile-name {
  margin-bottom: 12rpx;
}

.profile-phase {
  font-size: 30rpx;
  line-height: 1.55;
  max-width: 520rpx;
}

.profile-tag-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.profile-tag {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--muted-foreground);
  background: var(--surface-container-high, var(--surface-muted));
  border: 1rpx solid var(--border-subtle, var(--border));
}

.profile-section-kicker {
  margin: 24rpx 8rpx 20rpx;
  opacity: 0.75;
}

.profile-switch-scroll {
  width: 100%;
  margin-bottom: 32rpx;
  white-space: nowrap;
}

.profile-switch-inner {
  display: inline-flex;
  flex-direction: row;
  gap: 48rpx;
  padding: 8rpx 8rpx 16rpx;
}

.profile-switch-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  min-width: 140rpx;
}

.profile-switch-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--border);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted);
}

.profile-switch-ring {
  border-width: 4rpx;
  border-color: var(--accent);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.profile-switch-on .profile-switch-name {
  font-weight: 800;
  color: var(--foreground);
}

.profile-switch-letter {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--foreground);
}

.profile-switch-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: 999rpx;
  border: 2rpx dashed var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-muted);
}

.profile-switch-plus {
  font-size: 56rpx;
  font-weight: 400;
  color: var(--muted-foreground);
  line-height: 1;
}

.profile-switch-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--foreground);
}

.profile-group-title {
  margin: 16rpx 8rpx 20rpx;
}

.settings-group {
  padding: 0;
  overflow: hidden;
  border-radius: 28rpx;
  margin-bottom: 8rpx;
}

.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  gap: 20rpx;
}

.settings-row.border-b {
  border-bottom: 1rpx solid var(--border-subtle, var(--border));
}

.settings-row-tall {
  align-items: flex-start;
  padding-top: 40rpx;
  padding-bottom: 40rpx;
}

.settings-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-width: 0;
  flex: 1;
}

.settings-col {
  align-items: flex-start;
}

.settings-ico {
  font-size: 36rpx;
  width: 44rpx;
  text-align: center;
}

.settings-label {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--foreground);
}

.settings-desc {
  font-size: 24rpx;
  margin-top: 8rpx;
  line-height: 1.45;
}

.settings-chev {
  font-size: 40rpx;
  font-weight: 300;
  flex-shrink: 0;
}

.settings-right-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-pill {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--muted-foreground);
}

.care-stack {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.care-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  border: 4rpx solid var(--background);
  background: var(--surface-container);
  margin-right: -18rpx;
}

.care-plus {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  border: 4rpx solid var(--background);
  background: var(--accent);
  color: var(--primary-foreground);
  font-size: 20rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.theme-card {
  padding: 32rpx 28rpx 36rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.theme-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.theme-opt {
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid var(--border);
  background: var(--surface-muted);
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.theme-opt-on {
  border-color: var(--accent);
  background: var(--card);
}

.theme-opt-label {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--foreground);
}

.theme-opt-hint {
  font-size: 22rpx;
}

.link-card {
  padding: 28rpx 26rpx;
  margin-bottom: 32rpx;
}

.link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.link-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--foreground);
}

.link-desc {
  font-size: 22rpx;
  margin-top: 6rpx;
}

.link-chevron {
  font-size: 40rpx;
}

.sign-out-btn {
  width: 100%;
  margin-top: 8rpx;
  padding: 36rpx 24rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--destructive);
  background: transparent;
  border: 1rpx solid transparent;
}

.sign-out-btn::after {
  border: none;
}

.ghost-dismiss {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  background: var(--surface-muted);
  color: var(--foreground);
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-dismiss::after {
  border: none;
}
