.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 40rpx;
}

.login-hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.eyebrow {
  color: var(--muted-foreground);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.title {
  color: var(--foreground);
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.16;
}

.description {
  max-width: 620rpx;
  font-size: 28rpx;
  line-height: 1.7;
}

.login-card {
  padding: 36rpx;
}

.card-header,
.card-content,
.card-footer {
  display: flex;
  flex-direction: column;
}

.card-header {
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
}

.card-description {
  font-size: 28rpx;
  line-height: 1.6;
}

.card-content {
  gap: 24rpx;
  margin-bottom: 36rpx;
}

.notice {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  border: 1rpx solid var(--border);
  border-radius: 24rpx;
  background: var(--muted);
  padding: 24rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
}

.notice-text {
  font-size: 26rpx;
  line-height: 1.6;
}

.error-message {
  border: 1rpx solid rgba(220, 38, 38, 0.24);
  border-radius: 18rpx;
  background: rgba(220, 38, 38, 0.08);
  color: var(--destructive);
  font-size: 26rpx;
  padding: 18rpx 20rpx;
}

.login-button {
  width: 100%;
}
