.record-page {
  position: relative;
  min-height: 100vh;
}

.record-scroll {
  box-sizing: border-box;
}

.record-head {
  margin-bottom: 28rpx;
}

.record-main-title {
  margin-bottom: 12rpx;
}

.record-subtitle {
  max-width: 620rpx;
}

.record-banner {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
}

.record-search {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 28rpx;
  border-radius: 16rpx;
}

.record-search-glyph {
  font-size: 32rpx;
  opacity: 0.45;
  flex-shrink: 0;
}

.record-search-input {
  flex: 1;
  min-height: 48rpx;
  font-size: 28rpx;
  color: var(--input-color);
}

.input-placeholder {
  color: var(--muted-foreground);
  opacity: 0.72;
}

.filter-scroll {
  width: 100%;
  margin-bottom: 40rpx;
  white-space: nowrap;
}

.filter-inner {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.filter-pill {
  padding: 14rpx 36rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: 2rpx solid var(--border-interactive);
  color: var(--foreground);
  background: transparent;
}

.filter-pill-on {
  background: var(--accent);
  color: var(--primary-foreground);
  border-color: var(--accent);
  box-shadow: var(--inset-highlight);
}

.record-section {
  margin-bottom: 48rpx;
}

.record-section-label {
  margin-bottom: 24rpx;
}

.log-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--border-subtle);
  background: var(--log-card-bg);
}

.log-card-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.log-card-left {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 22rpx;
  min-width: 0;
}

.log-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: var(--surface-container);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  border: 1rpx solid var(--border-subtle);
}

.log-card-title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--foreground);
}

.log-card-meta {
  margin-top: 6rpx;
  font-size: 28rpx;
}

.log-badge {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: var(--surface-container);
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted-foreground);
  flex-shrink: 0;
}

.log-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
}

.log-dot-green {
  background: #22c55e;
}

.log-dot-amber {
  background: #f59e0b;
}

.log-body {
  margin-top: 24rpx;
}

.log-grid {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 24rpx;
}

.log-grid-cell {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  background: var(--surface-container);
}

.log-grid-label {
  font-size: 24rpx;
  font-weight: 600;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.log-grid-val {
  font-size: 36rpx;
  font-weight: 600;
}

.log-photo-placeholder {
  margin-top: 24rpx;
  padding: 80rpx;
  text-align: center;
  border-radius: 16rpx;
  border: 1rpx dashed var(--border);
  font-size: 26rpx;
}

.empty-hint {
  font-size: 28rpx;
  padding: 24rpx 0;
}

.record-fab {
  position: fixed;
  right: 36rpx;
  bottom: calc(200rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: var(--accent);
  color: var(--primary-foreground);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  font-weight: 300;
  line-height: 1;
  box-shadow: var(--inset-highlight);
  z-index: 90;
}

.record-fab-hover {
  opacity: 0.92;
}

.composer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx 28rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.composer-panel {
  padding: 36rpx 28rpx 40rpx;
}

.composer-title {
  margin-bottom: 24rpx;
}

.composer-textarea {
  width: 100%;
  min-height: 280rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.composer-submit {
  width: 100%;
}
