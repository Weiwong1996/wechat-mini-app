.record-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.screen-intro {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.screen-kicker {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.14em;
}

.screen-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--foreground);
}

.screen-desc {
  font-size: 26rpx;
  line-height: 1.55;
  max-width: 620rpx;
}

.record-sheet {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 32rpx 28rpx 36rpx;
  border-radius: 40rpx;
}

.sheet-label {
  font-size: 24rpx;
  font-weight: 700;
}

.record-textarea {
  width: 100%;
  min-height: 320rpx;
  box-sizing: border-box;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(13, 148, 136, 0.22);
  background: linear-gradient(180deg, #ffffff 0%, #f8fffe 100%);
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--foreground);
}

.record-ph {
  color: #94a3b8;
}

.submit-btn {
  margin-top: 8rpx;
}
