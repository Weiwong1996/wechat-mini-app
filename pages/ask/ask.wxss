.ask-page {
  display: flex;
  flex-direction: column;
}

.ask-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 32rpx;
}

.input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.ask-input {
  flex: 1;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
  background: var(--muted);
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-button {
  flex-shrink: 0;
  min-width: 140rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: var(--accent);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
}

.send-button::after {
  border: none;
}

.block-title {
  font-size: 24rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.answer-block {
  padding: 24rpx;
  border-radius: 20rpx;
  background: var(--accent-soft);
  border: 1rpx solid var(--border);
  font-size: 28rpx;
  line-height: 1.6;
}

.citation-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.citation-item {
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  border: 1rpx dashed var(--border);
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--muted-foreground);
}
