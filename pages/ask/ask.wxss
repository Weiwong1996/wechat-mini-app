/* 问答：对话区可滚动，底部输入区固定在自定义 tabBar 之上 */

/* 输入区表面：浅色 / 深色显式加固 */
.ask-page {
  --input-surface: #ffffff;
  --input-border: #eceae4;
  --footer-bg: rgba(247, 244, 237, 0.96);
  --bubble-ai-bg: #f1edec;
  --bubble-user-bg: #1c1c1c;
  --bubble-user-fg: #fcfbf8;
}

.ask-page.theme-dark {
  --input-surface: #323030;
  --input-border: rgba(244, 240, 239, 0.22);
  --footer-bg: rgba(42, 41, 41, 0.98);
  --bubble-ai-bg: #3a3838;
  --bubble-user-bg: #1c1c1c;
  --bubble-user-fg: #fcfbf8;
}

.page-root.ask-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.ask-layout {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
  box-sizing: border-box;
  padding-top: 8rpx;
}

.chat-scroll {
  flex: 1;
  height: 0;
  min-height: 280rpx;
  box-sizing: border-box;
  padding-bottom: 24rpx;
}

/* 为固定底栏留出滚动余量（快捷 pill + 输入行 + 安全区间隙） */
.chat-scroll-pad {
  height: 280rpx;
  flex-shrink: 0;
}

.chat-hint {
  font-size: 22rpx;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.msg-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.msg-row-user {
  flex-direction: row-reverse;
}

.msg-row-last {
  margin-bottom: 12rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  border: 1rpx solid var(--border);
}

.avatar-assist {
  background: var(--surface-muted);
  color: var(--foreground);
}

.avatar-user {
  background: var(--accent);
  color: var(--primary-foreground);
  border-color: transparent;
  box-shadow: var(--inset-highlight);
}

.msg-col {
  max-width: 82%;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.msg-col-user {
  align-items: flex-end;
}

.msg-meta {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.msg-meta-user {
  margin-right: 4rpx;
}

.bubble-ai {
  padding: 28rpx;
  border-radius: 24rpx;
  border-top-left-radius: 8rpx;
  background: var(--bubble-ai-bg);
  border: 1rpx solid var(--border);
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--foreground);
}

.bubble-text {
  display: block;
}

.tips-box {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}

.tips-heading {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  margin-bottom: 16rpx;
  opacity: 0.85;
}

.tips-line {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 28rpx;
  line-height: 1.45;
  margin-bottom: 14rpx;
}

.tips-line text {
  flex: 1;
  min-width: 0;
}

.tips-dot {
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: var(--foreground);
  flex-shrink: 0;
}

.bubble-user {
  padding: 28rpx;
  border-radius: 24rpx;
  border-top-right-radius: 8rpx;
  background: var(--bubble-user-bg);
  color: var(--bubble-user-fg);
  font-size: 28rpx;
  line-height: 1.65;
  box-shadow: var(--inset-highlight);
  text-align: left;
}

/* 底部固定：贴在自定义 tabBar 之上（高度可按真机微调） */
.ask-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(108rpx + env(safe-area-inset-bottom));
  z-index: 900;
  padding: 20rpx 28rpx 16rpx;
  border-top: 1rpx solid var(--border);
  background: var(--footer-bg);
  box-sizing: border-box;
}

.pill-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.pill-strip {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.quick-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  background: var(--card);
  border: 1rpx solid var(--border);
  color: var(--foreground);
}

.quick-pill:active {
  opacity: 0.88;
}

.quick-pill-ico {
  font-size: 28rpx;
}

.input-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.input-wrap {
  flex: 1;
  position: relative;
  min-width: 0;
}

.composer-input-field {
  width: 100%;
  min-height: 72rpx;
  padding: 18rpx 88rpx 18rpx 28rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.45;
  background: var(--input-surface);
  border: 2rpx solid var(--input-border);
  color: var(--foreground);
}

.input-ph {
  color: var(--muted-foreground);
}

.input-mic {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border-radius: 999rpx;
  color: var(--muted-foreground);
}

.input-mic-hover {
  opacity: 0.75;
}

/* 紧凑发送按钮 */
.send-btn {
  min-width: 100rpx;
  width: auto;
  min-height: 64rpx;
  padding: 0 24rpx;
  line-height: 64rpx;
  border-radius: 24rpx;
  border: none;
  background: var(--accent);
  color: var(--primary-foreground);
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: var(--inset-highlight);
  flex-shrink: 0;
}

.send-btn::after {
  border: none;
}

.send-btn-hover {
  opacity: 0.9;
}

/* 近期记录参考（Supabase 只读） */
.ref-card {
  margin: 16rpx 28rpx 0;
  padding: 20rpx 22rpx 22rpx;
  box-sizing: border-box;
}

.ref-line {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.ref-ttl {
  flex: 1;
  min-width: 0;
}

.ref-meta {
  flex-shrink: 0;
  font-size: 22rpx;
  opacity: 0.85;
}
