.ask-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.screen-intro {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.screen-kicker {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.14em;
}

.screen-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--foreground);
}

.screen-desc {
  font-size: 26rpx;
  line-height: 1.55;
}

.composer {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  padding: 14rpx 14rpx 14rpx 22rpx;
  border-radius: 999rpx;
}

.composer-input {
  flex: 1;
  min-height: 80rpx;
  padding: 0 12rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.composer-ph {
  color: #94a3b8;
}

.composer-send {
  flex-shrink: 0;
  min-width: 148rpx;
  min-height: 80rpx !important;
  border-radius: 999rpx !important;
  font-size: 28rpx !important;
}

.chat-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.chat-label {
  font-size: 24rpx;
  font-weight: 700;
}

.bubble {
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  font-size: 28rpx;
  line-height: 1.65;
}

.bubble-assist {
  background: #ffffff;
  border: 1rpx solid var(--border);
  box-shadow: 0 12rpx 40rpx rgba(15, 118, 110, 0.09);
  border-left: 8rpx solid var(--accent);
}

.pill-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.pill {
  padding: 18rpx 22rpx;
  border-radius: 999rpx;
  background: var(--accent-muted);
  border: 1rpx solid var(--border);
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--muted-foreground);
}
