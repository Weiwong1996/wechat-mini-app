<view class="page-root ask-page {{isDark ? 'theme-dark' : ''}}">
  <view class="ask-layout page-shell has-tab">
    <scroll-view
      class="chat-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      enable-flex
    >
      <view class="chat-hint muted-text">以下对话为界面演示；发送后将刷新助手回复占位内容。</view>

      <view class="msg-row msg-row-assist">
        <view class="avatar avatar-assist">AI</view>
        <view class="msg-col">
          <view class="msg-meta muted-text">助手 · 刚刚</view>
          <view class="bubble-ai">
            你好，我是你的育儿助手，可以结合睡眠节奏、喂养记录和成长里程碑给你一些参考思路。
          </view>
        </view>
      </view>

      <view class="msg-row msg-row-user">
        <view class="avatar avatar-user">我</view>
        <view class="msg-col msg-col-user">
          <view class="msg-meta msg-meta-user muted-text">你 · 演示</view>
          <view class="bubble-user">
            4 个月宝宝突然每两小时醒一次，这算睡眠倒退吗？
          </view>
        </view>
      </view>

      <view class="msg-row msg-row-assist msg-row-last">
        <view class="avatar avatar-assist">AI</view>
        <view class="msg-col">
          <view class="msg-meta muted-text">助手 · 刚刚</view>
          <view class="bubble-ai">
            <view class="bubble-text">{{answer}}</view>
            <view wx:if="{{tips.length}}" class="tips-box">
              <view class="tips-heading">可尝试</view>
              <view wx:for="{{tips}}" wx:key="*this" class="tips-line">
                <view class="tips-dot" />
                <text>{{item}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="chat-scroll-pad" />
    </scroll-view>
  </view>

  <view class="ask-footer">
    <scroll-view class="pill-scroll" scroll-x show-scrollbar="{{false}}" enable-flex>
      <view class="pill-strip">
        <view
          class="quick-pill"
          wx:for="{{quickPills}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="onTapQuickPill"
        >
          <text class="quick-pill-ico">{{item.icon}}</text>
          <text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="input-row">
      <view class="input-wrap">
        <input
          class="composer-input-field"
          placeholder="问问睡眠、喂养或发展里程碑…"
          value="{{question}}"
          bindinput="onInputQuestion"
          confirm-type="send"
          bindconfirm="onTapSend"
          placeholder-class="input-ph"
        />
        <view class="input-mic" bindtap="onTapMic" hover-class="input-mic-hover">🎤</view>
      </view>
      <button class="send-btn" bindtap="onTapSend" hover-class="send-btn-hover">发送</button>
    </view>
  </view>
</view>
