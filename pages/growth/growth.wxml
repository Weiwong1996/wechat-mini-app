<view class="page-shell growth-page">
  <view class="muted-text growth-note">{{note}}</view>

  <view class="card growth-card">
    <view class="chart-placeholder">
      <view class="chart-line" />
      <view class="chart-line muted" />
      <view class="chart-caption muted-text">趋势线占位（未接入真实图表）</view>
    </view>
  </view>

  <view class="card metric-card">
    <view wx:for="{{metrics}}" wx:key="name" class="metric-row">
      <view class="metric-name">{{item.name}}</view>
      <view class="metric-value">{{item.value}}</view>
      <view class="metric-hint muted-text">{{item.hint}}</view>
    </view>
  </view>
</view>
