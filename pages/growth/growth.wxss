.growth-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.growth-note {
  font-size: 26rpx;
  line-height: 1.5;
}

.growth-card {
  padding: 32rpx;
}

.chart-placeholder {
  position: relative;
  min-height: 220rpx;
  border-radius: 22rpx;
  background: linear-gradient(145deg, var(--accent-soft), var(--muted));
  border: 1rpx solid var(--border);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16rpx;
}

.chart-line {
  height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--accent), #5eead4);
  opacity: 0.9;
}

.chart-line.muted {
  width: 70%;
  opacity: 0.45;
}

.chart-caption {
  font-size: 24rpx;
  margin-top: 12rpx;
}

.metric-card {
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.metric-row {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 16rpx 24rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.metric-row:last-child {
  border-bottom: none;
}

.metric-name {
  flex: 0 0 120rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--foreground);
}

.metric-value {
  flex: 1;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--accent-strong);
}

.metric-hint {
  flex-basis: 100%;
  font-size: 24rpx;
}
