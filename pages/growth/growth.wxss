.growth-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.screen-intro {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.screen-kicker {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.14em;
}

.screen-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: -0.03em;
  color: var(--foreground);
}

.screen-desc {
  font-size: 26rpx;
  line-height: 1.55;
}

.chip-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.chip-active {
  background: linear-gradient(135deg, var(--accent) 0%, #14b8a6 100%);
  color: #ffffff;
}

.chip-quiet {
  background: rgba(255, 255, 255, 0.65);
  border: 1rpx solid var(--border);
}

.chart-card {
  padding: 28rpx 26rpx 32rpx;
  border-radius: 40rpx;
}

.chart-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 30rpx;
  font-weight: 800;
}

.chart-hint {
  font-size: 22rpx;
}

.fake-chart {
  position: relative;
  height: 260rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(204, 251, 241, 0.55) 0%, rgba(255, 255, 255, 0.92) 100%);
  border: 1rpx solid var(--border);
  overflow: hidden;
}

.fake-grid {
  position: absolute;
  inset: 24rpx;
  background-image:
    linear-gradient(0deg, rgba(148, 163, 184, 0.18) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(148, 163, 184, 0.14) 1rpx, transparent 1rpx);
  background-size: 100% 52rpx, 56rpx 100%;
  opacity: 0.55;
}

.fake-line {
  position: absolute;
  left: 48rpx;
  right: 40rpx;
  top: 58%;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--accent), #5eead4, var(--accent-strong));
  transform: rotate(-8deg);
  transform-origin: left center;
  opacity: 0.95;
}

.fake-dot {
  position: absolute;
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 4rpx solid var(--accent-strong);
  box-shadow: 0 4rpx 12rpx rgba(13, 148, 136, 0.35);
}

.fake-dot.d1 {
  left: 17%;
  top: 62%;
}

.fake-dot.d2 {
  left: 38%;
  top: 48%;
}

.fake-dot.d3 {
  left: 58%;
  top: 52%;
}

.fake-dot.d4 {
  left: 80%;
  top: 38%;
}

.metric-card {
  padding: 12rpx 0;
  border-radius: 40rpx;
}

.metric-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx 20rpx;
  padding: 26rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.metric-row:last-child {
  border-bottom: none;
}

.metric-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex: 0 0 auto;
}

.metric-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: var(--accent);
}

.metric-name {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--foreground);
}

.metric-value {
  margin-left: auto;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--accent-strong);
}

.metric-hint {
  flex-basis: 100%;
  font-size: 22rpx;
}
