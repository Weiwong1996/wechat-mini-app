<view class="dashboard-root">
  <view class="dash-hero card">
    <view class="dash-hero-top">
      <view class="dash-hero-copy">
        <view class="dash-kicker muted-text">工作台 · Parenting</view>
        <view class="dash-headline">你好，欢迎回来</view>
        <view class="dash-sub muted-text">记录日常、提问回顾、查看成长趋势</view>
      </view>
      <view class="dash-avatar" aria-hidden="true">
        <text class="dash-avatar-emoji">👶</text>
      </view>
    </view>
    <view class="dash-chip-row">
      <view class="dash-chip dash-chip-on">已登录</view>
      <view class="dash-chip muted-text">{{user && user.id ? '账号已绑定' : '资料待完善'}}</view>
    </view>
    <view class="dash-user mono muted-text">{{user && user.id ? user.id : 'Edge Function 未返回用户 ID'}}</view>
  </view>

  <view class="section-label muted-text">快捷入口</view>

  <view class="tile-grid">
    <view
      class="tile tile-half press-tile"
      hover-class="tile-active"
      hover-stay-time="80"
      bindtap="onTapRecord"
    >
      <view class="tile-icon-wrap tile-icon-teal">📝</view>
      <view class="tile-body">
        <view class="tile-title">录入</view>
        <view class="tile-desc muted-text">口述或记下宝宝日常</view>
      </view>
      <text class="tile-chevron muted-text">›</text>
    </view>

    <view
      class="tile tile-half press-tile"
      hover-class="tile-active"
      hover-stay-time="80"
      bindtap="onTapAsk"
    >
      <view class="tile-icon-wrap tile-icon-mint">💬</view>
      <view class="tile-body">
        <view class="tile-title">问答</view>
        <view class="tile-desc muted-text">基于记录的问答占位</view>
      </view>
      <text class="tile-chevron muted-text">›</text>
    </view>

    <view
      class="tile tile-full press-tile"
      hover-class="tile-active"
      hover-stay-time="80"
      bindtap="onTapGrowth"
    >
      <view class="tile-icon-wrap tile-icon-sea">📈</view>
      <view class="tile-body">
        <view class="tile-title">成长曲线</view>
        <view class="tile-desc muted-text">身高体重趋势 · 静态演示</view>
      </view>
      <text class="tile-chevron muted-text">›</text>
    </view>
  </view>

  <button class="ghost-button" hover-class="tile-active" bindtap="onTapLogout">退出登录</button>
</view>
