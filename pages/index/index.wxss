.dashboard-root {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 40rpx 28rpx 56rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.dash-hero {
  padding: 32rpx 28rpx 36rpx;
  border-radius: 40rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f3fffc 48%, #ecfeff 100%);
}

.dash-hero-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
}

.dash-hero-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dash-kicker {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
}

.dash-headline {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.15;
  color: var(--foreground);
  letter-spacing: -0.02em;
}

.dash-sub {
  font-size: 26rpx;
  line-height: 1.45;
}

.dash-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 36rpx;
  background: linear-gradient(145deg, var(--accent-soft), #ccfbf1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.86);
}

.dash-avatar-emoji {
  font-size: 52rpx;
}

.dash-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 28rpx;
}

.dash-chip {
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid var(--border);
}

.dash-chip-on {
  color: var(--accent-strong);
  border-color: rgba(13, 148, 136, 0.35);
  background: rgba(255, 255, 255, 0.98);
}

.dash-user {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.4;
  word-break: break-all;
}

.mono {
  font-family: ui-monospace, Menlo, monospace;
}

.section-label {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.04em;
  margin-top: 4rpx;
}

.tile-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 20rpx;
}

.tile {
  display: flex;
  flex-direction: row;
  align-items: center;
  box-sizing: border-box;
  padding: 24rpx 22rpx;
  border-radius: 32rpx;
  background: var(--card);
  border: 1rpx solid var(--border);
  box-shadow:
    0 10rpx 36rpx rgba(15, 118, 110, 0.07),
    0 2rpx 8rpx rgba(15, 23, 42, 0.03);
}

.tile-half {
  width: calc(50% - 10rpx);
  min-height: 200rpx;
}

.tile-full {
  width: 100%;
  min-height: 156rpx;
}

.press-tile {
  position: relative;
}

.tile-icon-wrap {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.tile-icon-teal {
  background: linear-gradient(160deg, var(--accent-soft), #99f6e4);
}

.tile-icon-mint {
  background: linear-gradient(160deg, rgba(20, 184, 166, 0.2), rgba(204, 251, 241, 0.9));
}

.tile-icon-sea {
  background: linear-gradient(160deg, rgba(45, 212, 191, 0.28), rgba(236, 254, 255, 0.95));
}

.tile-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.tile-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--foreground);
}

.tile-desc {
  font-size: 22rpx;
  line-height: 1.35;
}

.tile-chevron {
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
  margin-left: 8rpx;
  flex-shrink: 0;
}

.ghost-button {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  background: rgba(255, 255, 255, 0.65);
  color: var(--muted-foreground);
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-button::after {
  border: none;
}
