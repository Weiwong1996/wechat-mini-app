.dash-topbar {
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx 16rpx;
  border-bottom: 1rpx solid var(--border);
  background: var(--page-bg);
}

.dash-brand-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.dash-avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  overflow: hidden;
  border: 1rpx solid var(--border);
  background: var(--surface-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dash-avatar-letter {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--foreground);
}

.dash-brand-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.dash-app-name {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: -0.03em;
  color: var(--foreground);
}

.dash-app-sub {
  font-size: 22rpx;
}

.dash-top-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dash-icon-btn {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border);
  font-size: 24rpx;
  font-weight: 600;
}

.dash-main {
  padding: 32rpx 28rpx 0;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  box-sizing: border-box;
}

.dash-date {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
}

.dash-hero-title {
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -0.04em;
  color: var(--foreground);
}

.dash-hero-lead {
  font-size: 28rpx;
  line-height: 1.55;
  max-width: 640rpx;
}

.insight-card {
  padding: 36rpx 32rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.insight-card::before {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 160rpx;
  height: 160rpx;
  background: var(--primary);
  opacity: 0.04;
  border-bottom-left-radius: 100%;
}

.insight-badge-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.insight-emoji {
  font-size: 28rpx;
  opacity: 0.85;
}

.insight-badge {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--foreground);
}

.insight-headline {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.35;
  margin-bottom: 12rpx;
  color: var(--foreground);
}

.insight-body {
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.insight-cta {
  width: 100%;
  min-height: 88rpx;
  font-size: 28rpx;
}

.section-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 20rpx;
}

.section-heading {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--foreground);
}

.section-link {
  font-size: 24rpx;
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.past-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.past-cell {
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  padding: 22rpx 20rpx 24rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.past-cell-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.past-ico {
  font-size: 36rpx;
}

.past-time {
  font-size: 20rpx;
}

.past-label {
  font-size: 22rpx;
}

.past-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--foreground);
}

.past-sub {
  font-size: 20rpx;
}

.bento-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.sleep-card {
  padding: 28rpx 24rpx 32rpx;
}

.sleep-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 28rpx;
}

.sleep-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--foreground);
}

.sleep-sub {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.sleep-more {
  font-size: 36rpx;
  padding: 0 8rpx;
}

.sleep-bars {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-between;
  gap: 8rpx;
  height: 200rpx;
  padding: 0 4rpx;
}

.sleep-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  position: relative;
  min-width: 0;
  min-height: 200rpx;
}

.sleep-bar-h {
  width: 100%;
  max-width: 48rpx;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  background: var(--surface-muted);
  border: 1rpx solid var(--border);
  min-height: 24rpx;
}

.sleep-day {
  font-size: 20rpx;
  color: var(--muted-foreground);
}

.sleep-day-on {
  color: var(--foreground);
  font-weight: 800;
}

.sleep-bar-wrap.is-on .sleep-bar-h {
  background: var(--accent);
  border-color: transparent;
  box-shadow: var(--inset-highlight);
}

.sleep-badge {
  position: absolute;
  top: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  font-weight: 700;
  color: var(--foreground);
  white-space: nowrap;
}

.mile-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1c1c1c;
  color: #fcfbf8;
  padding: 36rpx 28rpx 40rpx;
}

.theme-dark .mile-card {
  background: #1a1a1a;
  border: 1rpx solid rgba(244, 240, 239, 0.12);
}

.mile-decor {
  position: absolute;
  bottom: -80rpx;
  right: -80rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
}

.mile-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mile-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mile-spark {
  font-size: 32rpx;
}

.mile-title {
  font-size: 32rpx;
  font-weight: 700;
}

.mile-desc {
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(252, 251, 248, 0.75);
}

.mile-btn {
  margin-top: 12rpx;
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  background: #fcfbf8;
  color: #1c1c1c;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.mile-btn::after {
  border: none;
}

.foot-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.foot-link {
  text-decoration: underline;
  text-underline-offset: 4rpx;
}

.foot-dot {
  opacity: 0.45;
}

.dash-foot {
  font-size: 20rpx;
  line-height: 1.45;
  word-break: break-all;
  text-align: center;
}

.mono {
  font-family: ui-monospace, Menlo, monospace;
}
